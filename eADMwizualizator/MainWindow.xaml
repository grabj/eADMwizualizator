<Window x:Class="eADMwizualizator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:eADMwizualizator"
        xmlns:vm="clr-namespace:eADMwizualizator.ViewModels"
        xmlns:helpers="clr-namespace:eADMwizualizator.Helpers"
        mc:Ignorable="d"
        Title="Wizualizator paczki eADM" 
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:PlikViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Konwertery -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Styl dla nowoczesnych przycisków -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004578"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Styl dla przycisku akcji (pomarańczowy) -->
        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#FF6F00"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E65100"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C43E00"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Styl dla przycisku sukcesu (zielony) -->
        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#107C10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0E6B0E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0C5A0C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Styl dla małych przycisków (kompaktowy) -->
        <Style x:Key="SmallButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <!-- Styl dla paneli z zaokrąglonymi rogami -->
        <Style x:Key="ModernBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <!-- Styl dla GridSplitter -->
        <Style x:Key="ModernGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="Width" Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="SizeWE"/>
            <Setter Property="Margin" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0078D4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Styl dla zakładek -->
        <Style x:Key="ModernTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="ModernTabItemStyle" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" 
                                Background="Transparent" 
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="20,10"
                                Margin="0,0,5,0">
                            <ContentPresenter ContentSource="Header" 
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="Border" Property="Background" Value="#F3F8FC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F9F9F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <!-- Styl dla TreeView -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
        </Style>

        <!-- Styl dla ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Górny panel - Otwórz paczkę + Ustawienia czcionki -->
        <Border Grid.Row="0" 
                Background="White" 
                BorderBrush="#E1E1E1" 
                BorderThickness="0,0,0,1"
                Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Lewa strona - Otwórz paczkę -->
                <Button Grid.Column="0"
                        Content="📦 Otwórz paczkę eADM" 
                        Click="OtworzPaczke_Click" 
                        Style="{StaticResource ActionButtonStyle}"
                        Height="40"
                        MinWidth="180"
                        HorizontalAlignment="Left"/>

                <!-- Prawa strona - Ustawienia czcionki -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="🔤 Rozmiar czcionki:" 
                              VerticalAlignment="Center"
                              FontSize="12"
                              FontWeight="SemiBold"
                              Foreground="#666666"
                              Margin="0,0,10,0"/>
                    
                    <Slider x:Name="FontSizeSlider" 
                           Minimum="8" 
                           Maximum="24" 
                           Value="13"
                           Width="120"
                           TickFrequency="1"
                           IsSnapToTickEnabled="True"
                           ValueChanged="FontSizeSlider_ValueChanged"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                    
                    <TextBlock Text="{Binding ElementName=FontSizeSlider, Path=Value, StringFormat={}{0:F0}}"
                              VerticalAlignment="Center"
                              FontSize="12"
                              FontWeight="Bold"
                              Foreground="#0078D4"
                              Width="25"
                              TextAlignment="Center"
                              Margin="0,0,10,0"/>
                    
                    <Button Content="↺" 
                           Click="ResetFont_Click" 
                           Style="{StaticResource SmallButtonStyle}"
                           ToolTip="Reset rozmiaru czcionki"
                           Width="32"
                           Padding="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Główna zawartość z GridSplitterami -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="350" MinWidth="250"/>
            </Grid.ColumnDefinitions>

            <!-- Lewy panel - Nawigacja -->
            <Border Grid.Column="0" Style="{StaticResource ModernBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tytuł -->
                    <TextBlock Grid.Row="0" 
                              Text="Nawigacja" 
                              FontSize="18" 
                              FontWeight="Bold" 
                              Foreground="#333333"
                              Margin="0,0,0,15"/>

                    <!-- Zakładki -->
                    <TabControl Grid.Row="1" 
                               SelectedIndex="{Binding ActiveTabIndex}"
                               Style="{StaticResource ModernTabControlStyle}">
                        <TabItem Header="📄 Dokumenty" Style="{StaticResource ModernTabItemStyle}">
                            <ListBox ItemsSource="{Binding Dokumenty}" 
                                    SelectedItem="{Binding SelectedDocumentFile}"
                                    DisplayMemberPath="Tytul"
                                    Margin="0,10,0,0"/>
                        </TabItem>
                        
                        <TabItem Header="📁 Sprawy" Style="{StaticResource ModernTabItemStyle}">
                            <TreeView ItemsSource="{Binding Nodes}" 
                                     SelectedItemChanged="SprawyTree_SelectedItemChanged"
                                     Margin="0,10,0,0">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Documents}">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                                        <HierarchicalDataTemplate.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Tytul}"/>
                                            </DataTemplate>
                                        </HierarchicalDataTemplate.ItemTemplate>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </TabItem>
                        
                        <TabItem Header="🏷️ Metadane" Style="{StaticResource ModernTabItemStyle}">
                            <ListBox ItemsSource="{Binding Metadane}" 
                                    SelectedItem="{Binding SelectedMetadataFile}"
                                    DisplayMemberPath="Tytul"
                                    Margin="0,10,0,0"/>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <!-- GridSplitter między nawigacją a dokumentami -->
            <GridSplitter Grid.Column="1" 
                         Style="{StaticResource ModernGridSplitterStyle}"
                         ShowsPreview="True"
                         ToolTip="Przeciągnij, aby zmienić szerokość panelu nawigacji" Margin="0,10,0,10"/>

            <!-- Środkowy panel - Podgląd dokumentu -->
            <Border Grid.Column="2" Style="{StaticResource ModernBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Nagłówek -->
                    <Border Grid.Row="0" 
                           Background="#F3F8FC" 
                           CornerRadius="4" 
                           Padding="12"
                           Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Podgląd dokumentu" 
                                      FontSize="16" 
                                      FontWeight="Bold" 
                                      Foreground="#0078D4"
                                      Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding SelectedDocumentDisplayName}" 
                                      FontSize="12"
                                      Foreground="#666666"
                                      TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <!-- Zawartość dokumentu -->
                    <ContentControl Grid.Row="1" 
                                   helpers:UniversalDocumentViewer.DocumentSource="{Binding SelectedFilePath}"/>
                </Grid>
            </Border>

            <!-- GridSplitter między dokumentami a metadanymi -->
            <GridSplitter Grid.Column="3" 
                         Style="{StaticResource ModernGridSplitterStyle}"
                         ShowsPreview="True"
                         ToolTip="Przeciągnij, aby zmienić szerokość panelu metadanych" Margin="0,10,0,10"/>

            <!-- Prawy panel - Metadane -->
            <Border Grid.Column="4" Style="{StaticResource ModernBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Nagłówek metadanych -->
                    <Border Grid.Row="0" 
                           Background="#F3F8FC" 
                           CornerRadius="4" 
                           Padding="12"
                           Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Metadane" 
                                      FontSize="16" 
                                      FontWeight="Bold" 
                                      Foreground="#0078D4"
                                      Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding SelectedMetadataDisplayName}" 
                                      FontSize="12"
                                      Foreground="#666666"
                                      TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <!-- Zawartość metadanych -->
                    <Grid Grid.Row="1">
                        <!-- WebBrowser dla HTML -->
                        <WebBrowser x:Name="MetadataWebBrowser" 
                                   helpers:WebBrowserHelper.Html="{Binding MetadataHtmlContent}"
                                   Visibility="Collapsed"
                                   d:IsHidden="True"/>

                        <!-- ListView dla surowych metadanych -->
                        <ListView x:Name="Metadata_List" 
                                 ItemsSource="{Binding SelectedMetadata}"
                                 BorderThickness="0"
                                 Background="White"
                                 Visibility="Visible">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F9F9F9" 
                                           CornerRadius="4" 
                                           Padding="10" 
                                           Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" 
                                                      FontWeight="SemiBold" 
                                                      FontSize="12"
                                                      Foreground="#0078D4"
                                                      Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Value}" 
                                                      TextWrapping="Wrap"
                                                      FontSize="{DynamicResource AppFontSize}"
                                                      Foreground="#333333"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
