<Window x:Class="eADMwizualizator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:eADMwizualizator"
        xmlns:viewModel="clr-namespace:eADMwizualizator.ViewModels"
        xmlns:helpers="clr-namespace:eADMwizualizator.Helpers"
        mc:Ignorable="d"
        MinHeight="720" MinWidth="960" 
        WindowState="Maximized">
    <Window.DataContext>
        <viewModel:PlikViewModel/>
    </Window.DataContext>

    <Window.Style>
        <Style TargetType="{x:Type Window}">
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        </Style>
    </Window.Style>

    <Window.Resources>
        <!-- zasoby -->
        <DataTemplate x:Key="FileItemTemplate">
            <TextBlock Text="{Binding Tytul}" TextTrimming="CharacterEllipsis" />
        </DataTemplate>

        <HierarchicalDataTemplate x:Key="SprawaNodeTemplate" ItemsSource="{Binding Documents}"
                                  ItemTemplate="{StaticResource FileItemTemplate}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                <TextBlock Text="  " />
                <TextBlock Text="{Binding Documents.Count, StringFormat='({0})'}" Foreground="Gray"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Szablon dla metadanych -->
        <DataTemplate x:Key="MetadataItemTemplate">
            <StackPanel Margin="4">
                <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                <TextBlock Text="{Binding Value}" TextWrapping="Wrap" Margin="0,2,0,4"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <DockPanel DockPanel.Dock="Top" LastChildFill="True" Margin="0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}">                
                <TextBlock Text="Rozmiar czcionki" VerticalAlignment="Center" Margin="4,0" ToolTip="Ustaw rozmiar czcionki" />
                <!-- Inicjalizacja opźniona, żeby pobrać wartość z Resource AppFontSize -->
                <Slider x:Name="FontSizeSlider"
                        Width="200"
                        Minimum="8" Maximum="24" 
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        Value="{Binding FontSize, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                        ValueChanged="FontSizeSlider_ValueChanged"
                        SmallChange="1" LargeChange="1"
                        VerticalAlignment="Center"
                        Margin="8,0" />
                <TextBlock Text="{Binding Value, ElementName=FontSizeSlider, StringFormat='{}{0:0}'}"
                           VerticalAlignment="Center" Margin="2,0,4,0"/>
                <!-- Przycisk szybkiego resetu -->
                <Button Margin="6,0"
                        ToolTip="Zresetuj rozmiar czcionki"
                        Click="ResetFont_Click"
                        VerticalAlignment="Center" Background="{x:Null}" BorderBrush="{x:Null}">
                    <TextBlock Text="⟲" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>

            <!-- Menu wypełnia pozostałą przestrzeń po lewej -->
            <Menu BorderThickness="0,0,1,0" BorderBrush="DimGray">
                <MenuItem Header="_Plik" TabIndex="1">
                    <MenuItem Header="_Otwórz plik..." Click="OtworzPaczke_Click" />
                    <Separator/>
                    <MenuItem Header="_Wyjdź" Click="Exit_Click"/>
                </MenuItem>

                <MenuItem Header="_Widok" TabIndex="2">
                    <MenuItem Header="Pokaż/ukryj panel otwierania paczki" ToolTip="Zmiana widoczości przycisku otwierania paczki"
                          Click="ShowOpenPackage_Click"/>
                    <!-- jeśli zaznaczone, panel nie będzie automatycznie zamykany po otwarciu paczki -->
                    <MenuItem x:Name="AlwaysShowOpenPackageMenuItem"
                          Header="Nie zamykaj panelu otwierania paczki" IsCheckable="True"
                          IsChecked="{Binding NieZamykajPaneluOtworzPaczke, Mode=TwoWay}"
                          ToolTip="Przycisk 'Otwórz paczkę' pozostanie widoczny po zaimportowaniu paczki"/>
                    <Separator/>
                    <MenuItem Header="Zresetuj rozmiar czcionki" Click="ResetFont_Click"/>
                    <Separator/>
                </MenuItem>
                <MenuItem Header="Pomoc" TabIndex="3">
                    <MenuItem Header="O programie"/>
                </MenuItem>
            </Menu>
        </DockPanel>

        <!-- Główny grid z miejscem na splitter między Selection a Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- lewy panel -->
                <ColumnDefinition Width="2*"/>
                <!-- miejsce dla splittera -->
                <ColumnDefinition Width="5"/>
                <!-- główny content -->
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <!-- lewy panel -->
            <Border Grid.Column="0" x:Name="SelectionBorder" BorderThickness="0,0,1,1" BorderBrush="DimGray" Background="{DynamicResource {x:Static SystemColors.MenuBarBrushKey}}" Margin="0">
                <Grid x:Name="Selection">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- panel Otwórz Paczkę -->
                    <Border Grid.Row="0" x:Name="TopPanelBorder" Padding="1">
                        <Border.RenderTransform>
                            <TranslateTransform Y="-20"/>
                        </Border.RenderTransform>

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Opacity" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOpenPackageVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                     From="-20" To="0" Duration="0:0:0.18" />
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0" To="1" Duration="0:0:0.18"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button x:Name="OpenPackageButton" Width="120" Height="40" Margin="1,3,1,5"
                                    Content="_Otwórz paczkę" Click="OtworzPaczke_Click" Cursor="Hand"
                                    FontSize="15" Background="#FFD8E8F7"
                                    ToolTip="Uruchomienie systemowego eksploratora plików"/>
                        </StackPanel>
                    </Border>

                    <!-- Listy plików -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" >
                        <TabControl SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}" >
                            <TabItem >
                                <TabItem.Header>
                                    <TextBlock Text="Dokumenty" FontWeight="SemiBold"/>
                                </TabItem.Header>
                                <ListView ItemsSource="{Binding Dokumenty}" ItemTemplate="{StaticResource FileItemTemplate}"
                                          SelectedItem="{Binding SelectedDocumentFile, Mode=TwoWay}"/>
                            </TabItem>
                            <TabItem >
                                <TabItem.Header>
                                    <TextBlock Text="Sprawy" FontWeight="SemiBold"/>
                                </TabItem.Header>
                                <!-- wstawione bezpośrednio: drzewo spraw powiązane z PlikViewModel.Nodes -->
                                <TreeView x:Name="SprawyTree"
                                    ItemsSource="{Binding Nodes}"
                                    ItemTemplate="{StaticResource SprawaNodeTemplate}"
                                    SelectedItemChanged="SprawyTree_SelectedItemChanged" > 
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem">
                                            <Setter Property="IsExpanded" Value="True"/>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                </TreeView>
                            </TabItem>
                            <TabItem Header="Metadane" >
                                <ListView ItemsSource="{Binding Metadane}" ItemTemplate="{StaticResource FileItemTemplate}"
                                          SelectedItem="{Binding SelectedMetadataFile, Mode=TwoWay}"/>
                            </TabItem>
                        </TabControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- splitter między lewą a prawą częścią -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          Background="#FFCCCCCC" BorderThickness="0,1" BorderBrush="DimGray"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Cursor="SizeWE"/>

            <!-- główny content -->
            <Border Grid.Column="2" x:Name="ContentBorder" BorderThickness="1" BorderBrush="DimGray" Background="Transparent" Margin="0">
                <Grid x:Name="Content">
                    <!-- teraz: wiersz 0 = zawartość, wiersz 1 = nagłówki poniżej -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- dokument (góra) -->
                    <Border Grid.Row="0" Grid.Column="0" BorderBrush="DimGray" Background="#FFD8E8F7" BorderThickness="0,0,1,0" Margin="0">
                        <ContentControl helpers:PdfContentControlExtensions.PdfSource="{Binding SelectedFilePath}"/>
                    </Border>

                    <!-- Metadata (góra) -->
                    <Border Grid.Row="0" Grid.Column="2" Background="#FFE5E5E5" BorderThickness="1,0,0,0" BorderBrush="DimGray" Margin="0">
                        <ListBox x:Name="Metadata_List" ItemsSource="{Binding SelectedMetadata}" ItemTemplate="{StaticResource MetadataItemTemplate}"
                                 HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" BorderThickness="0"  />
                    </Border>

                    <!-- pojedynczy splitter użyty dla obu wierszy -->
                    <GridSplitter Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                  Width="5"
                                  Background="#FFCCCCCC"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch"
                                  ShowsPreview="True"
                                  ResizeBehavior="PreviousAndNext"
                                  ResizeDirection="Columns"
                                  Cursor="SizeWE"
                                  IsTabStop="False"
                                  Panel.ZIndex="1"/>

                    <!-- Nagłówki poniżej: dokument (dolny lewy) -->
                    <Border Grid.Row="1" Grid.Column="0" BorderThickness="0,1,1,0" BorderBrush="Gray" 
                            Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}" Padding="6,2,6,2">
                        <TextBlock Text="{Binding SelectedDocumentDisplayName}" 
                                   ToolTip="{Binding SelectedFilePath}"
                                   TextTrimming="CharacterEllipsis" 
                                   VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Nagłówki poniżej: metadata (dolny prawy) -->
                    <Border Grid.Row="1" Grid.Column="2" BorderThickness="1,1,0,0" BorderBrush="Gray" 
                            Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}" Padding="6,2,6,2">
                        <TextBlock Text="{Binding SelectedMetadataDisplayName}" 
                                   ToolTip="{Binding SelectedMetadataFile.Sciezka}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
