<Window x:Class="eADMwizualizator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:eADMwizualizator"
        xmlns:vm="clr-namespace:eADMwizualizator.ViewModels"
        xmlns:helpers="clr-namespace:eADMwizualizator.Helpers"
        mc:Ignorable="d"
        Title="Wizualizator paczki eADM" 
        Height="900" Width="1600"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/eADM_ikona.ico"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.DataContext>
        <vm:PlikViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- 1. Konwertery -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- 2. Style pomocnicze dla Slidera -->
        <Style x:Key="SliderButtonStyle" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SliderThumbStyle" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <!-- Cień pod thumbem -->
                            <Ellipse Fill="#30000000" 
                                    Width="24" 
                                    Height="24"
                                    Margin="0,2,0,0">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            
                            <!-- Okrągły uchwyt -->
                            <Ellipse x:Name="ThumbEllipse"
                                    Fill="#0078D4"
                                    Width="20" 
                                    Height="20"
                                    Stroke="White"
                                    StrokeThickness="2"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbEllipse" Property="Width" Value="22"/>
                                <Setter TargetName="ThumbEllipse" Property="Height" Value="22"/>
                                <Setter TargetName="ThumbEllipse" Property="Fill" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbEllipse" Property="Width" Value="24"/>
                                <Setter TargetName="ThumbEllipse" Property="Height" Value="24"/>
                                <Setter TargetName="ThumbEllipse" Property="Fill" Value="#004578"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 3. Główny styl Slidera -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Ścieżka slidera -->
                            <Border x:Name="TrackBackground"
                                   Grid.Row="1"
                                   Height="4"
                                   Background="#E1E1E1"
                                   CornerRadius="2"
                                   Margin="5,0"/>
                            
                            <!-- Wypełniona część ścieżki (od początku do thumba) -->
                            <Border x:Name="PART_SelectionRange"
                                   Grid.Row="1"
                                   Height="4"
                                   Background="#0078D4"
                                   CornerRadius="2"
                                   HorizontalAlignment="Left"
                                   Margin="5,0,0,0"/>
    
                            <!-- Track z thumbem -->
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Style="{StaticResource SliderButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Style="{StaticResource SliderButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Style="{StaticResource SliderThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 4. Style przycisków - ROZJAŚNIONE KOLORY -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                               Background="{TemplateBinding Background}" 
                               CornerRadius="4"
                               Padding="{TemplateBinding Padding}">
                            <!-- Subtelny cień -->
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" 
                                                 BlurRadius="4" 
                                                 ShadowDepth="2" 
                                                 Direction="270"
                                                 Opacity="0.2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            TextOptions.TextRenderingMode="ClearType"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1767B7"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0D47A1"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BBDEFB"/>
                    <Setter Property="Foreground" Value="#FF838E94"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 5. Style paneli -->
        <Style x:Key="ModernBorderStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="White" Opacity="0.95"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <!-- Efekt cienia (głębia) -->
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" 
                                     BlurRadius="8"
                                     ShadowDepth="1" 
                                     Direction="270"
                                     Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="Width" Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="SizeWE"/>
            <Setter Property="Margin" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0078D4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 6. Style zakładek -->
        <Style x:Key="ModernTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
        </Style>

        <Style x:Key="ModernTabItemStyle" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" 
                                Background="Transparent" 
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="8,10"
                                Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header" 
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="Border" Property="Background" Value="#F3F8FC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F9F9F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <!-- 7. Style kontrolek -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
        </Style>

        <!-- Styl dla ListBoxItem (Fluent Design)-->
        <Style x:Key="FluentListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                               Background="Transparent"
                               BorderThickness="0"
                               CornerRadius="4"
                               Margin="4,2">
                            <!-- Padding dynamiczny -->
                            <ContentPresenter Margin="8,4"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#F0F3F8" Offset="0"/>
                                            <GradientStop Color="#E8EDF5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E8F4FF"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styl dla TreeViewItem (Fluent Design) -->
        <Style x:Key="FluentTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Główny wiersz z zawartością -->
                            <Border x:Name="ItemBorder"
                                   Grid.Row="0"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   CornerRadius="4"
                                   Margin="2,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Toggle button -->
                                    <ToggleButton x:Name="Expander"
                                                Grid.Column="0"
                                                IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                ClickMode="Press"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Margin="0,0,4,0"
                                                Padding="2"
                                                VerticalAlignment="Center">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" 
                                                       Padding="2"
                                                       CornerRadius="3">
                                                    <Path x:Name="ExpandPath"
                                                         Data="M 4 6 L 10 12 L 4 18"
                                                         Stroke="#666666"
                                                         StrokeThickness="2"
                                                         Width="14"
                                                         Height="14"
                                                         Stretch="Uniform"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="0"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ExpandPath"
                                                                                   Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                                                   To="90"
                                                                                   Duration="0:0:0.2">
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ExpandPath"
                                                                                   Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                                                   To="0"
                                                                                   Duration="0:0:0.2">
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ExpandPath" Property="Stroke" Value="#0078D4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    
                                    <!-- Dynamiczny padding -->
                                    <ContentPresenter x:Name="PART_Header"
                                                    Grid.Column="1"
                                                    ContentSource="Header"
                                                    Margin="4,4"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                </Grid>
                            </Border>
                            
                            <!-- Elementy potomne -->
                            <ItemsPresenter x:Name="ItemsHost"
                                           Grid.Row="1"
                                           Margin="4,0,0,0"
                                           Visibility="Collapsed"/>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <!-- Ukryj strzałkę jeśli brak dzieci -->
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            
                            <!-- Pokaż dzieci gdy rozwinięte -->
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            
                            <!-- Efekt hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#F0F3F8" Offset="0"/>
                                            <GradientStop Color="#E8EDF5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            
                            <!-- Efekt selekcji -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E8F4FF"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            
                            <!-- Gdy zaznaczony i hover równocześnie -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#D6EBFF"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Górny panel - Otwórz paczkę + Ustawienia czcionki -->
        <Border Grid.Row="0" 
                Background="White" 
                BorderBrush="#E1E1E1" 
                BorderThickness="0,0,0,1"
                Padding="20,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Lewa strona - Otwórz paczkę -->
                <Button Grid.Column="0"
                        Content="📦 Otwórz paczkę eADM" 
                        Click="OtworzPaczke_Click" 
                        Style="{StaticResource ModernButtonStyle}"
                        Height="40"
                        MinWidth="180"
                        HorizontalAlignment="Left"/>

                <!-- Prawa strona - Ustawienia czcionki -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Rozmiar czcionki:" 
                              VerticalAlignment="Center"
                              FontSize="{DynamicResource AppFontSize}"
                              FontWeight="SemiBold"
                              Foreground="#666666"
                              Margin="0,0,10,0"/>
                    
                    <!-- Nowoczesny slider -->
                    <Slider x:Name="FontSizeSlider" 
                           Minimum="10" 
                           Maximum="22" 
                           Value="13"
                           Width="160"
                           TickFrequency="1"
                           IsSnapToTickEnabled="True"
                           ValueChanged="FontSizeSlider_ValueChanged"
                           Style="{StaticResource ModernSliderStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                    
                    <TextBlock Text="{Binding ElementName=FontSizeSlider, Path=Value, StringFormat={}{0:F0}}"
                              VerticalAlignment="Center"
                              FontSize="{DynamicResource AppFontSize}"
                              FontWeight="Bold"
                              Foreground="#0078D4"
                              Width="25"
                              TextAlignment="Center"
                              Margin="0,0,10,0"/>

                    <Button Content="↺" 
                           Click="ResetFont_Click" 
                           Style="{StaticResource ModernButtonStyle}"
                            FontSize="{DynamicResource AppFontSizeBig}"
                           ToolTip="Reset rozmiaru czcionki"
                           Width="40"
                           Height="40"
                           Padding="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Główna zawartość z GridSplitterami -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" MinWidth="200" MaxWidth="600"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="400" MinWidth="250" MaxWidth="600"/>
            </Grid.ColumnDefinitions>

            <!-- Lewy panel - Nawigacja -->
            <Border Grid.Column="0" Style="{StaticResource ModernBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tytuł -->
                    <TextBlock Grid.Row="0" 
                              Text="Nawigacja" 
                              FontSize="{DynamicResource AppFontSizeLarge}" 
                              FontWeight="Bold" 
                              Foreground="#333333"
                              Margin="0,0,0,15"/>

                    <!-- Zakładki z adaptacyjnym wyświetlaniem - ZAWSZE W JEDNEJ LINII -->
                    <TabControl Grid.Row="1" 
                               x:Name="NavigationTabControl"
                               SelectedIndex="{Binding ActiveTabIndex}"
                               Style="{StaticResource ModernTabControlStyle}">
    
                        <!-- Ustaw panel poziomy z przewijaniem -->
                        <TabControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" 
                                           IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </TabControl.ItemsPanel>
    
                        <!-- Włącz przewijanie poziome gdy zakładki się nie mieszczą -->
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Panel z zakładkami - z przewijaniem poziomym -->
                                    <ScrollViewer Grid.Row="0" 
                                                 HorizontalScrollBarVisibility="Hidden"
                                                 VerticalScrollBarVisibility="Disabled"
                                                 PanningMode="HorizontalOnly"
                                                 Background="White"
                                                 Margin="0">
                                        <TabPanel IsItemsHost="True" 
                                                 Background="Transparent"/>
                                    </ScrollViewer>
                                    
                                    <!-- Zawartość zakładki -->
                                    <Border Grid.Row="1"
                                           Background="White"
                                           BorderBrush="{TemplateBinding BorderBrush}"
                                           BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter ContentSource="SelectedContent"/>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </TabControl.Template>
    
                        <TabItem Style="{StaticResource ModernTabItemStyle}">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📄" 
                                              FontSize="{DynamicResource AppFontSizeLarge}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,5,0"/>
                                    <TextBlock x:Name="DokumentyText"
                                              Text="Dokumenty" 
                                              FontSize="{DynamicResource AppFontSizeBig}"
                                              VerticalAlignment="Center"/>
                                </StackPanel>
                            </TabItem.Header>
                            <ListBox ItemsSource="{Binding Dokumenty}" 
                                    SelectedItem="{Binding SelectedDocumentFile}"
                                    ItemContainerStyle="{StaticResource FluentListBoxItemStyle}"
                                    Margin="0,10,0,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Tytul}" 
                                                  FontSize="{DynamicResource AppFontSize}"
                                                  TextTrimming="CharacterEllipsis">
                                            <TextBlock.ToolTip>
                                                <TextBlock>
                                                    <Run Text="{Binding Tytul, Mode=OneWay}"/>
                                                </TextBlock>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
    
                        <TabItem Style="{StaticResource ModernTabItemStyle}">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁" 
                                              FontSize="{DynamicResource AppFontSizeLarge}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,5,0"/>
                                    <TextBlock x:Name="SprawyText"
                                              Text="Sprawy" 
                                              FontSize="{DynamicResource AppFontSizeBig}"
                                              VerticalAlignment="Center"/>
                                </StackPanel>
                            </TabItem.Header>
                            <TreeView ItemsSource="{Binding Nodes}" 
                                     SelectedItemChanged="SprawyTree_SelectedItemChanged"
                                     Margin="0,10,0,0">
                                <!-- ItemContainerStyle -->
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource FluentTreeViewItemStyle}"/>
                                </TreeView.ItemContainerStyle>
                                
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Documents}">
                                        <TextBlock Text="{Binding Key}" 
                                                  Typography.Capitals="AllSmallCaps"
                                                  Typography.Kerning="True"
                                                  FontSize="{DynamicResource AppFontSizeBig}"
                                                  ToolTip="{Binding DisplayName}"/>
                                        <HierarchicalDataTemplate.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Tytul}"
                                                          FontSize="{DynamicResource AppFontSize}"
                                                          TextTrimming="CharacterEllipsis"
                                                          ToolTip="{Binding Tytul}"/>
                                            </DataTemplate>
                                        </HierarchicalDataTemplate.ItemTemplate>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </TabItem>
    
                        <!--<TabItem Style="{StaticResource ModernTabItemStyle}">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏷️" 
                                              FontSize="{DynamicResource AppFontSizeLarge}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,5,0"/>
                                    <TextBlock x:Name="MetadaneText"
                                              Text="Metadane" 
                                              FontSize="{DynamicResource AppFontSizeBig}"
                                              VerticalAlignment="Center"/>
                                </StackPanel>
                            </TabItem.Header>
                            <ListBox ItemsSource="{Binding Metadane}" 
                                    SelectedItem="{Binding SelectedMetadataFile}"
                                    Margin="0,10,0,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Tytul}" 
                                                  FontSize="{DynamicResource AppFontSize}"
                                                  TextTrimming="CharacterEllipsis"
                                                  ToolTip="{Binding Tytul}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>-->
                    </TabControl>
                </Grid>
            </Border>

            <!-- GridSplitter między nawigacją a dokumentami -->
            <GridSplitter Grid.Column="1" 
                         Style="{StaticResource ModernGridSplitterStyle}"
                         ShowsPreview="True"
                         ToolTip="Przeciągnij, aby zmienić szerokość panelu nawigacji" Margin="0,10,0,10"/>

            <!-- Środkowy panel - Podgląd dokumentu -->
            <Border Grid.Column="2" Style="{StaticResource ModernBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Nagłówek -->
                    <Border Grid.Row="0" 
                           Background="#F3F8FC" 
                           CornerRadius="4" 
                           Padding="10, 5, 2, 5"
                           Margin="0,0,0,15">
                        <Border.Effect>
                            <DropShadowEffect Color="#0078D4" BlurRadius="5" ShadowDepth="0" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Nagłówek "Podgląd dokumentu" -->
                            <TextBlock Text="Podgląd dokumentu" 
                                      FontSize="{DynamicResource AppFontSizeLarge}" 
                                      FontWeight="Bold" 
                                      Foreground="#0078D4"
                                      Margin="0,0,0,5"/>

                            <TextBlock Text="{Binding SelectedDocumentDisplayName}" 
                                      FontSize="{DynamicResource AppFontSize}"
                                      Foreground="#666666"
                                      TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <!-- Zawartość dokumentu -->
                    <ContentControl Grid.Row="1" 
                       helpers:UniversalDocumentViewer.DocumentSource="{Binding SelectedFilePath}"
                       helpers:UniversalDocumentViewer.TextFontSize="{Binding ElementName=FontSizeSlider, Path=Value}"/>
                </Grid>
            </Border>

            <!-- GridSplitter między dokumentami a metadanymi -->
            <GridSplitter Grid.Column="3" 
                         Style="{StaticResource ModernGridSplitterStyle}"
                         ShowsPreview="True"
                         ToolTip="Przeciągnij, aby zmienić szerokość panelu metadanych" Margin="0,10,0,10"/>

            <!-- Prawy panel - Metadane -->
            <Border Grid.Column="4" Style="{StaticResource ModernBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Nagłówek metadanych -->
                    <Border Grid.Row="0" 
                           Background="#F3F8FC" 
                           CornerRadius="4" 
                           Padding="10, 5, 10, 5"
                           Margin="0,0,0,15">
                        <Border.Effect>
                            <DropShadowEffect Color="#0078D4" BlurRadius="5" ShadowDepth="0" Opacity="0.1"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Lewa strona - teksty -->
                            <StackPanel Grid.Column="0">
                                <!-- Nagłówek "Metadane" -->
                                <TextBlock Text="Metadane" 
                                          FontSize="{DynamicResource AppFontSizeLarge}" 
                                          FontWeight="Bold" 
                                          Foreground="#0078D4"
                                          Margin="0,0,0,5"/>

                                <TextBlock Text="{Binding SelectedMetadataDisplayName}" 
                                          FontSize="{DynamicResource AppFontSize}"
                                          Foreground="#666666"
                                          TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            
                            <!-- Prawa strona - przycisk drukowania -->
                            <Button x:Name="PrintMetadataButton"
                                   Grid.Column="1"
                                   Content="🖨"
                                   Click="PrintMetadata_Click"
                                   Style="{StaticResource ModernButtonStyle}"
                                   Width="40"
                                   Height="40"
                                   FontSize="{DynamicResource AppFontSizeLarge}"
                                   Padding="0"
                                   ToolTip="Drukuj metadane"
                                   VerticalAlignment="Center"
                                   Cursor="Hand"
                                   IsEnabled="False">
                                <Button.Effect>
                                    <DropShadowEffect Color="#000000" 
                                                     BlurRadius="6" 
                                                     ShadowDepth="2" 
                                                     Direction="270"
                                                     Opacity="0.25"/>
                                </Button.Effect>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Zawartość metadanych -->
                    <Grid Grid.Row="1">
                        <!-- WebBrowser dla HTML -->
                        <WebBrowser x:Name="MetadataWebBrowser" 
                                   helpers:WebBrowserHelper.Html="{Binding MetadataHtmlContent}"
                                   Visibility="Collapsed"
                                   d:IsHidden="True"/>

                        <!-- ListView dla surowych metadanych -->
                        <ListView x:Name="Metadata_List" 
                                 ItemsSource="{Binding SelectedMetadata}"
                                 BorderThickness="0"
                                 Background="White"
                                 Visibility="Visible">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F9F9F9" 
                                           CornerRadius="4" 
                                           Padding="10" 
                                           Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" 
                                                      FontWeight="SemiBold" 
                                                      FontSize="{DynamicResource AppFontSize}"
                                                      Foreground="#0078D4"
                                                      Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Value}" 
                                                      TextWrapping="Wrap"
                                                      FontSize="{DynamicResource AppFontSize}"
                                                      Foreground="#333333"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
