<UserControl x:Class="eADMwizualizator.Views.SprawyListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:eADMwizualizator.ViewModels"
             xmlns:model="clr-namespace:eADMwizualizator.Models"
             MinHeight="200" MinWidth="200">
    <UserControl.Resources>
        <HierarchicalDataTemplate DataType="{x:Type vm:SprawaNodeViewModel}" ItemsSource="{Binding Documents}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                <TextBlock Text="  " />
                <TextBlock Text="{Binding Documents.Count, StringFormat='({0})'}" Foreground="Gray"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type model:Plik}">
            <TextBlock Text="{Binding Tytul}" TextTrimming="CharacterEllipsis" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <TreeView x:Name="SprawyTree"
                  ItemsSource="{Binding Nodes}"
                  SelectedItemChanged="SprawyTree_SelectedItemChanged" />
    </Grid>
</UserControl>
